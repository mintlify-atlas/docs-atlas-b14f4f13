  "keyFeatures": [
    "Autenticación de usuarios",
    "Gestión de catálogo de productos con inventario",
    "Caja de cobro (POS)",
    "Generación de tickets de venta en PDF",
    "Historial de ventas con reimpresión y cancelación",
    "Reportes de ventas y productos",
    "Configuración del sistema"
  ],
  "publicApiSurface": [
    "Login::index() - Página de inicio de sesión",
    "Login::login() - Autenticación de usuario",
    "Login::logout() - Cerrar sesión",
    "Productos::index() - Listar productos activos",
    "Productos::create() - Crear nuevo producto",
    "Productos::update($id) - Actualizar producto",
    "Productos::delete($id) - Eliminar producto (soft delete)",
    "Caja::index() - Interfaz de caja de cobro",
    "Caja::inserta() - Agregar producto a venta temporal",
    "Caja::elimina() - Eliminar producto de venta temporal",
    "Ventas::index() - Historial de ventas",
    "Ventas::guarda() - Guardar venta y generar folio",
    "Ventas::generaTicket($id) - Generar PDF de ticket",
    "Ventas::cancelar($id) - Cancelar venta",
    "Reportes::verReporteVentas() - Reporte de ventas por rango de fechas",
    "Reportes::verReporteProductos() - Reporte de inventario de productos",
    "Configuracion::edit() - Ver configuración del sistema",
    "Configuracion::update() - Actualizar configuración"
  ]
